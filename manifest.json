{
  "manifest_version": 3,
  "name": "KeepFocus",
  "version": "1.1",
  "description": "Advanced website blocker with scheduling and redirect features",

  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms"
  ],

  "host_permissions": ["*://*/*"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "128": "icons/icon128.png"
  }
}
